pragma solidity ^0.8.34;

import {Test} from "@forge-std/Test.sol";
import {Address} from "@/libraries/Address.sol";
import {WOTSp} from "@/libraries/WOTSp.sol";

contract WOTSpTest is Test {
    using WOTSp for WOTSp.Context;

    WOTSp.Context public wots;

    function setUp() public {
        wots = WOTSp.Context({w: 0, seed: sha256("seed"), adrs: Address.make(0, 42)});
    }

    function test_Pubkey() public {
        bytes32 sk = sha256("secret");

        wots.w = 4;
        {
            bytes32 pk = this.pubkey(sk);
            assertEq(pk, hex"6d539b4fefd6ece332857d188ae4639d713c030ad0e4260d870fae9fa666b2e3");
        }

        wots.w = 16;
        {
            bytes32 pk = this.pubkey(sk);
            assertEq(pk, hex"4484096778b1823fbe6674c965b28371dcb39e7beea3edc61f74e105882cb515");
        }
    }

    function test_Sign() public {
        bytes32 sk = sha256("secret");
        bytes32 m = sha256("Hello, WOTS+!");

        wots.w = 4;
        {
            bytes32[] memory sig = this.sign(sk, m);
            assertEq0(
                abi.encodePacked(sig),
                hex""
            );
        }

        wots.w = 16;
        {
            bytes32[] memory sig = this.sign(sk, m);
            assertEq0(
                abi.encodePacked(sig),
                hex""
            );
        }
    }

    function test_Recover() public {
        bytes32 sk = sha256("secret");
        bytes32 m = sha256("Hello, WOTS+!");

        uint256[2] memory ws = [uint256(4), 16];
        for (uint256 i = 0; i < ws.length; i++) {
            wots.w = ws[i];
            bytes32[] memory sig = this.sign(sk, m);
            bytes32 pk = this.recover(m, sig);
            assertEq(pk, this.pubkey(sk));
        }
    }

    function pubkey(bytes32 sk) external view returns (bytes32 pkl) {
        return wots.pubkey(sk);
    }

    function sign(bytes32 sk, bytes32 m) external view returns (bytes32[] memory sig) {
        return wots.sign(sk, m);
    }

    function recover(bytes32 m, bytes32[] calldata sig) external view returns (bytes32 pk) {
        return wots.recover(m, sig);
    }
}
